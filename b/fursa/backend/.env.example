# =============================================
# FURSA BACKEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# For local development:
DATABASE_URL=postgresql://username:password@localhost:5432/fursa_db

# For Render.com (they give you this URL automatically):
# DATABASE_URL=postgresql://...

# JWT
JWT_SECRET=your_super_secret_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=uploads/cvs

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin default account (used in seed script)
ADMIN_EMAIL=admin@fursa.sy
ADMIN_PASSWORD=1234
ADMIN_NAME=مدير النظام
